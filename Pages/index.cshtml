@page
@model NorthwindWeb.Pages.ViewCustomers

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Northwind Console</title>
    </head>
    <body>
        <h1>Northwind Console</h1>
        <h2>Viewing Database</h2>
        <h3>@Model.DbName</h3>

        <table border="1">
            <th>Customer ID</th>
            <th>Customer Name</th>
            <th>Contact Name</th>
            <th>Address</th>
            <th>City</th>
            <th>Postal Code</th>
            <th>Country</th>
            <th>&nbsp;</th>

            @foreach (Customer customer in @Model.Customers){
                <tr>
                    <td>@customer.CustomerID</td>
                    <td>@customer.CustomerName</td>
                    <td>@customer.ContactName</td>
                    <td>@customer.Address</td>
                    <td>@customer.City</td>
                    <td>@customer.PostalCode</td>
                    <td>@customer.Country</td>

                    <td>
                        <form action="~/Modifiy" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="hdnCustomerID" value="@customer.CustomerID"/>
                            <input type="submit" value="Modifiy"/>
                        </form>
                    </td>
                </tr>
            }
        </table>
    </body>
</html>